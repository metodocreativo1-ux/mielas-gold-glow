<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} — Mielas Hair Design</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  {{ 'landing.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body>
  {{ content_for_layout }}
  <script>
    (function () {
      var bar = document.querySelector('.cta-bar');
      var hero = document.getElementById('hero');
      if (!bar || !hero) return;
      bar.style.display = 'none';
      window.addEventListener('scroll', function () {
        bar.style.display = hero.getBoundingClientRect().bottom < 0 ? 'flex' : 'none';
      }, { passive: true });
    })();
  </script>
</body>
</html>