</head>
<body>
  {{ content_for_layout }}

  <script>
    // Carousel
    (function() {
      var track = document.getElementById('carouselTrack');
      if (!track) return;
      var current = 0;
      var total = track.children.length;
      function perView() { return window.innerWidth < 768 ? 1 : 3; }
      function update() {
        var n = perView();
        var max = total - n;
        if (current > max) current = max;
        track.style.transform = 'translateX(-' + (current * (100 / n)) + '%)';
      }
      var prev = document.querySelector('.carousel-prev');
      var next = document.querySelector('.carousel-next');
      if (prev) prev.addEventListener('click', function() { if (current > 0) { current--; update(); } });
      if (next) next.addEventListener('click', function() { if (current < total - perView()) { current++; update(); } });
      window.addEventListener('resize', update, { passive: true });
    })();

    // FAQ Accordion
    (function() {
      document.querySelectorAll('.faq-question').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var item = btn.closest('.faq-item');
          var isOpen = item.classList.contains('open');
          document.querySelectorAll('.faq-item').forEach(function(i) { i.classList.remove('open'); });
          if (!isOpen) item.classList.add('open');
        });
      });
    })();
  </script>
</body>
