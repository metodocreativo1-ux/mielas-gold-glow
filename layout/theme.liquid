<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page_title }} — Mielas Hair Design</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garant:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
  {{ 'landing.css' | asset_url | stylesheet_tag }}
  {{ content_for_header }}
</head>
<body>
  {{ content_for_layout }}

  <div id="floatingBar" class="floating-bar">
    <span class="floating-text">¿Lista para transformar tu técnica?</span>
    <a href="/cart/52102418530606:1" class="btn floating-btn">Quiero inscribirme →</a>
  </div>

  <script>
    // Floating bar
    (function() {
      var bar = document.getElementById('floatingBar');
      if (!bar) return;
      window.addEventListener('scroll', function() {
        if (window.scrollY > 400) { bar.classList.add('visible'); }
        else { bar.classList.remove('visible'); }
      }, { passive: true });
    })();

    // Carousel
    (function() {
      var track = document.getElementById('carouselTrack');
      if (!track) return;
      var current = 0;
      var total = track.children.length;
      function perView() { return window.innerWidth < 768 ? 1 : 3; }
      function update() {
        var n = perView();
        var max = total - n;
        if (current > max) current = max;
        track.style.transform = 'translateX(-' + (current * (100 / n)) + '%)';
      }
      var prev = document.querySelector('.carousel-prev');
      var next = document.querySelector('.carousel-next');
      if (prev) prev.addEventListener('click', function() { if (current > 0) { current--; update(); } });
      if (next) next.addEventListener('click', function() { if (current < total - perView()) { current++; update(); } });
      window.addEventListener('resize', update, { passive: true });
    })();

    // FAQ Accordion
    (function() {
      document.querySelectorAll('.faq-question').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var item = btn.closest('.faq-item');
          var isOpen = item.classList.contains('open');
          document.querySelectorAll('.faq-item').forEach(function(i) { i.classList.remove('open'); });
          if (!isOpen) item.classList.add('open');
        });
      });
    })();
  </script>
</body>
</html>