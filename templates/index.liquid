<!-- ══════════════════════════════════════════
     SOBRE PAMELA
══════════════════════════════════════════ -->
<section id="pamela">
<div class="container">
<div class="pamela-grid">
<div class="pamela-photo">
<div class="pamela-stack">
  <img src="{{ 'pamela-bio.jpg' | asset_url }}" alt="Pamela Mielas">
  <img src="https://cdn.shopify.com/s/files/1/0990/8679/5054/files/IMG_0089.jpg" alt="Pamela Mielas">
  <img src="https://cdn.shopify.com/s/files/1/0990/8679/5054/files/IMG_0090.jpg" alt="Pamela Mielas">
